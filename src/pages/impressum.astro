---
import BaseLayout from "../components/BaseLayout.astro";
import site from "../content/de/site.json";

const page = site.legal.impressum;
---

<BaseLayout title={page.pageTitle} description={page.metaDescription} path="/impressum/">
  <section class="legal-page" aria-labelledby="page-title">
    <p class="eyebrow">Rechtliche Angaben</p>
    <h1 id="page-title">{page.title}</h1>
    <p>{page.intro}</p>
  </section>

  {
    page.sections.map((section, index) => (
      <section class="section" aria-labelledby={`impressum-section-${index}`}>
        <h2 id={`impressum-section-${index}`}>{section.title}</h2>
        <ul>
          {section.items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    ))
  }
</BaseLayout>
