---
import BaseLayout from "../components/BaseLayout.astro";
import FocusCard from "../components/FocusCard.astro";
import HeroVisual from "../components/HeroVisual.astro";
import Section from "../components/Section.astro";
import SkillGroup from "../components/SkillGroup.astro";
import StationCard from "../components/StationCard.astro";
import Timeline from "../components/Timeline.astro";
import * as educationContent from "../content/de/education.md";
import * as experienceContent from "../content/de/experience.md";
import * as profileContent from "../content/de/profile.md";
import additionalActivities from "../content/de/additionalActivities.json";
import focusAreas from "../content/de/focusAreas.json";
import interests from "../content/de/interests.json";
import skills from "../content/de/skills.json";

const profile = profileContent.frontmatter;
const education = educationContent.frontmatter;
const experience = experienceContent.frontmatter;
---

<BaseLayout title={profile.pageTitle} description={profile.metaDescription} path="/">
  <HeroVisual profile={profile} />

  <Section id="ausbildung" title={education.sectionTitle} eyebrow="Akademischer Rahmen">
    <Timeline label={education.sectionTitle}>
      {
        education.items.map((item) => (
          <StationCard
            period={item.period}
            title={item.title}
            subtitle={item.institution}
            details={item.details}
          />
        ))
      }
    </Timeline>
  </Section>

  <Section id="erfahrung" title={experience.sectionTitle} eyebrow="Praxisstationen" tone="timeline">
    <Timeline label={experience.sectionTitle}>
      {
        experience.items.map((item) => (
          <StationCard
            period={item.period}
            title={item.role}
            subtitle={item.organization}
            details={item.details}
          />
        ))
      }
    </Timeline>
  </Section>

  <Section id="weitere-taetigkeiten" title={additionalActivities.sectionTitle} eyebrow="Ergänzend">
    <Timeline label={additionalActivities.sectionTitle}>
      {
        additionalActivities.items.map((item) => (
          <StationCard
            period={item.period}
            title={item.role}
            subtitle={item.organization}
            details={item.details}
          />
        ))
      }
    </Timeline>
  </Section>

  <Section id="kompetenzen" title={skills.sectionTitle} eyebrow="Werkzeugfelder">
    <div class="grid grid--skills">
      {
        skills.groups.map((skillGroup) => (
          <SkillGroup group={skillGroup} />
        ))
      }
    </div>
  </Section>

  <Section id="schwerpunkte" title={focusAreas.sectionTitle} eyebrow="Anwendungsnah" tone="featured">
    <div class="grid grid--focus">
      {
        focusAreas.items.map((focus, index) => (
          <FocusCard focus={focus} labels={focusAreas.labels} index={index} />
        ))
      }
    </div>
  </Section>

  <Section id="interessen" title={interests.sectionTitle} eyebrow="Persönlich">
    <ul class="tag-list" aria-label="Interessen">
      {interests.items.map((interest) => <li>{interest}</li>)}
    </ul>
  </Section>

  <Section id="kontakt" title={profile.contact.sectionTitle} eyebrow="Erreichbarkeit" tone="contact">
    <div class="contact-panel">
      <p>{profile.contact.emailLabel}</p>
      <p>{profile.contact.emailHint}</p>
      <p>{profile.contact.linkedIn}</p>
      <p>{profile.contact.location}</p>
    </div>
  </Section>
</BaseLayout>
