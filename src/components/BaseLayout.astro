---
import site from "../content/de/site.json";
import "../styles/global.css";
import Footer from "./Footer.astro";
import Header from "./Header.astro";

const {
  title = "Portfolio in Vorbereitung",
  description = "Technische Portfolio-Website in Vorbereitung.",
  path = "/",
  type = "website",
  noindex = false
} = Astro.props;

const basePath = import.meta.env.BASE_URL || "/";
const normalizedBase = basePath === "/" ? "" : basePath.replace(/\/$/, "");
const withBase = (targetPath) =>
  targetPath.startsWith("/") ? `${normalizedBase}${targetPath}` || "/" : targetPath;
const siteUrl = Astro.site?.toString() ?? site.seo.baseUrl;
const canonicalUrl = new URL(withBase(path), siteUrl).toString();
const robotsContent =
  noindex || import.meta.env.PUBLIC_SITE_NOINDEX === "true"
    ? "noindex, nofollow"
    : "index, follow";
const ogImage = site.seo.defaultImage
  ? new URL(withBase(site.seo.defaultImage), siteUrl).toString()
  : "";
const faviconHref = withBase("/favicon.svg");
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <meta property="og:site_name" content={site.seo.siteName} />
    <meta property="og:locale" content={site.seo.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <Header site={site} />
    <main class="shell" id="inhalt">
      <slot />
    </main>
    <Footer site={site} />
  </body>
</html>
